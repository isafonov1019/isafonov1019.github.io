---
import OrthodoxCross from './OrthodoxCross.astro';
import { getEntry } from 'astro:content';

const site = (await getEntry('settings', 'site'))?.data;

const links = [
  { href: '/', label: 'Главная' },
  { href: '/raspisanie', label: 'Расписание' },
  { href: '/novosti', label: 'Новости' },
  { href: '/o-hrame', label: 'О храме' },
  { href: '/kontakty', label: 'Контакты' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-col">
      <div class="footer-brand">
        <span class="brand-emblem"><OrthodoxCross /></span>
        <span class="brand-name">{site?.name ?? 'Храм'}</span>
      </div>
      {site?.welcome && <p>{site.welcome}</p>}
    </div>

    <div class="footer-col">
      <h3>Контакты</h3>
      {site?.address && <p>Адрес: {site.address}</p>}
      {site?.phone && <p>Телефон: {site.phone}</p>}
      {site?.email && <p>Эл. почта: {site.email}</p>}
    </div>

    <div class="footer-col">
      <h3>Разделы</h3>
      <ul class="footer-nav">
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      © {year} {site?.name ?? 'Храм'}
    </div>
  </div>
</footer>
