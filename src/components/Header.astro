---
import OrthodoxCross from './OrthodoxCross.astro';
import { getEntry } from 'astro:content';
import { NAV_LINKS as links } from '../data/navigation';

// Название и подпись берём из общих настроек (settings/site.md)
const site = (await getEntry('settings', 'site'))?.data;

// Подсветка текущего раздела в меню
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-emblem"><OrthodoxCross /></span>
      <span class="brand-text">
        <span class="brand-name">{site?.name ?? 'Храм'}</span>
        {site?.subtitle && <span class="brand-sub">{site.subtitle}</span>}
      </span>
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="Открыть меню"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Основное меню">
      <ul>
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class={isActive(l.href) ? 'active' : ''}
              aria-current={isActive(l.href) ? 'page' : undefined}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // Класс .js ставится ранним скриптом в BaseLayout —
  // здесь только логика открытия/закрытия меню.
  const btn = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const nav = document.getElementById('site-nav');

  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open') ?? false;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Закрыть меню' : 'Открыть меню');
  });

  // Закрываем меню после перехода по ссылке (на телефоне)
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Открыть меню');
    });
  });
</script>
