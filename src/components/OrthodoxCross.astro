---
// Православный восьмиконечный крест — простая аккуратная эмблема.
// Цвет наследуется от родителя (currentColor), размер задаётся через CSS.
// Декоративный элемент: скрыт от экранных дикторов (aria-hidden),
// рядом всегда есть текст.
---
<svg viewBox="0 0 32 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
  <g fill="currentColor">
    <!-- вертикальный столб -->
    <rect x="14.6" y="2" width="2.8" height="43" rx="0.6" />
    <!-- верхняя малая перекладина (титло) -->
    <rect x="9.5" y="8.5" width="13" height="2.4" rx="0.6" />
    <!-- главная перекладина -->
    <rect x="4.5" y="16.5" width="23" height="3" rx="0.8" />
    <!-- нижняя косая перекладина (подножие) -->
    <polygon points="8,31.5 24,26.5 24,29.6 8,34.6" />
  </g>
</svg>
