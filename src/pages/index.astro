---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrthodoxCross from '../components/OrthodoxCross.astro';
---

<BaseLayout>
  <!-- Приветственный экран -->
  <section class="hero">
    <div class="container">
      <span class="hero-emblem"><OrthodoxCross /></span>
      <h1>
        Добро пожаловать<br />
        <span class="hero-name">[УТОЧНИТЬ: название храма]</span>
      </h1>
      <div class="ornament"><span></span></div>
      <p class="lead">
        [УТОЧНИТЬ: короткое приветственное слово настоятеля или описание храма
        в 1–2 предложениях]
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/raspisanie">Расписание богослужений</a>
        <a class="btn btn-outline" href="/kontakty">Как добраться</a>
      </div>
    </div>
  </section>

  <!-- Быстрая информация -->
  <div class="container">
    <div class="info-cards">
      <div class="card info-card">
        <h3>Ближайшее богослужение</h3>
        <p><span class="placeholder">[УТОЧНИТЬ: дата и время]</span></p>
      </div>
      <div class="card info-card">
        <h3>Адрес</h3>
        <p><span class="placeholder">[УТОЧНИТЬ: адрес храма]</span></p>
      </div>
      <div class="card info-card">
        <h3>Телефон</h3>
        <p><span class="placeholder">[УТОЧНИТЬ: телефон]</span></p>
      </div>
    </div>
  </div>

  <!-- Приветственный текст -->
  <section class="section">
    <div class="container welcome">
      <h2>О нашем храме</h2>
      <div class="ornament"><span></span></div>
      <p>
        [УТОЧНИТЬ: несколько предложений о храме — когда основан, чем живёт
        приход, кому посвящён престол. Настоящий текст возьмём у настоятеля.]
      </p>
      <p>
        <a class="btn btn-outline" href="/o-hrame">Подробнее об истории</a>
      </p>
    </div>
  </section>
</BaseLayout>
