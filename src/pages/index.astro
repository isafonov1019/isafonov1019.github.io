---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrthodoxCross from '../components/OrthodoxCross.astro';
import { getCollection, getEntry } from 'astro:content';

const site = (await getEntry('settings', 'site'))?.data;

// Ближайшее богослужение: первый сегодняшний/будущий день с расписания
const today = new Date();
today.setHours(0, 0, 0, 0);
const nextDay = (await getCollection('services'))
  .filter((e) => e.data.date >= today)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())[0];

const dateFmt = new Intl.DateTimeFormat('ru-RU', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
});
const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const nextService = nextDay
  ? {
      date: capitalize(dateFmt.format(nextDay.data.date)),
      first: nextDay.data.services[0],
    }
  : null;
---

<BaseLayout>
  <!-- Приветственный экран -->
  <section class="hero">
    <div class="container">
      <span class="hero-emblem"><OrthodoxCross /></span>
      {site?.subtitle && <p class="hero-kicker">{site.subtitle}</p>}
      <h1 class="hero-name">{site?.name ?? 'Храм'}</h1>
      <div class="ornament"><span></span></div>
      {site?.welcome && <p class="lead">{site.welcome}</p>}
      <div class="hero-actions">
        <a class="btn btn-primary" href="/raspisanie">Расписание богослужений</a>
        <a class="btn btn-outline" href="/kontakty">Как добраться</a>
      </div>
    </div>
  </section>

  <!-- Быстрая информация -->
  <div class="container">
    <div class="info-cards">
      <div
        class="card info-card"
        data-next-service
        data-date={nextDay ? nextDay.data.date.toISOString().slice(0, 10) : undefined}
      >
        <h3>Ближайшее богослужение</h3>
        {nextService ? (
          <p data-next-info>
            <strong>{nextService.date}</strong><br />
            {nextService.first ? `${nextService.first.time} — ${nextService.first.name}` : ''}
          </p>
        ) : (
          <p><span class="placeholder">[УТОЧНИТЬ: расписание]</span></p>
        )}
        <p data-next-stale hidden>Смотрите актуальное расписание на странице служб.</p>
        <p><a href="/raspisanie">Всё расписание →</a></p>
      </div>
      <div class="card info-card">
        <h3>Адрес</h3>
        <p>{site?.address ?? '—'}</p>
      </div>
      <div class="card info-card">
        <h3>Телефон</h3>
        <p>{site?.phone ?? '—'}</p>
      </div>
    </div>
  </div>

  <!-- Приветственный текст -->
  <section class="section">
    <div class="container welcome">
      <h2>О нашем храме</h2>
      <div class="ornament"><span></span></div>
      {site?.about ? (
        <p>{site.about}</p>
      ) : (
        <p><span class="placeholder">[УТОЧНИТЬ: короткий текст о храме]</span></p>
      )}
      <p>
        <a class="btn btn-outline" href="/o-hrame">Подробнее об истории</a>
      </p>
    </div>
  </section>

  <script is:inline>
    // Если сборка сайта была давно и дата службы прошла —
    // показываем нейтральный текст вместо устаревшей даты.
    (function () {
      var card = document.querySelector('[data-next-service]');
      if (!card || !card.getAttribute('data-date')) return;
      var d = new Date();
      var p = function (n) { return String(n).padStart(2, '0'); };
      var today = d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate());
      if (card.getAttribute('data-date') < today) {
        var info = card.querySelector('[data-next-info]');
        var stale = card.querySelector('[data-next-stale]');
        if (info) info.hidden = true;
        if (stale) stale.hidden = false;
      }
    })();
  </script>
</BaseLayout>
