---
// Общий каркас страницы: <head>, шапка, основное содержимое и подвал.
// Каждая страница оборачивается в этот макет и передаёт свой заголовок.

// Шрифты (файлы лежат в проекте, без загрузки со стороннего сервера).
// PT Serif — для заголовков, PT Sans — для основного текста.
// Только реально используемые начертания: заголовки всегда жирные (serif 700),
// текст — sans 400/700 (+курсив по требованию). Меньше файлов — быстрее загрузка.
import '@fontsource/pt-serif/700.css';
import '@fontsource/pt-sans/400.css';
import '@fontsource/pt-sans/400-italic.css';
import '@fontsource/pt-sans/700.css';

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

interface Props {
  title?: string;
  description?: string;
}

const site = (await getEntry('settings', 'site'))?.data;
const siteName = site?.name ?? 'Храм';

const {
  title,
  description = `${siteName}${site?.subtitle ? `, ${site.subtitle}` : ''}: расписание богослужений, новости прихода, история храма, контакты и пожертвования.`,
} = Astro.props;

const fullTitle = title ? `${title} — ${siteName}` : siteName;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Помечаем как можно раньше, что JavaScript работает:
      // от этого зависит сворачиваемое меню на телефоне.
      // Без JS меню остаётся полностью видимым.
      document.documentElement.classList.add('js');
    </script>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6d1f2b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <!-- Карточка ссылки в мессенджерах и соцсетях -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
  </head>
  <body>
    <a class="skip-link" href="#main">Перейти к содержанию</a>
    <Header />
    <main id="main" class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
